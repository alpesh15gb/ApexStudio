# Apex Studio — Environment Configuration
# Copy this to .env and fill in your values

# Application
APP_NAME=Apex Studio
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-key
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
APP_CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# URLs
APP_API_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:8080
APP_PREVIEW_DOMAIN=localhost

# Database
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apex_studio
DATABASE_SYNC_URL=postgresql://apex:apex@localhost:5432/apex_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-this-to-a-jwt-secret-key

# Docker SDK
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK_NAME=apex_network
WORKSPACE_BASE_PATH=./workspaces

# S3 / Object Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=apex-studio
S3_REGION=us-east-1
S3_SECURE=false

# AI / Omniroute
OMNIROUTE_API_KEY=your-omniroute-api-key
OMNIROUTE_BASE_URL=https://api.omniroute.ai/v1
OMNIROUTE_DEFAULT_MODEL=claude-sonnet-5
OMNIROUTE_FALLBACK_MODEL=gpt-4o

# SMTP / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@apexstudio.com

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
